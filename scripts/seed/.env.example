# Copy to scripts/seed/.env and fill in. This file is gitignored (.env is in .gitignore).
#
# Find these in the Supabase dashboard → Project Settings → API.

# Your project URL (same one the app uses).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# The SERVICE-ROLE key (secret, admin). NOT the anon/public key.
# It bypasses Row-Level Security so the seed can create users and content.
# Treat it like a password — never commit it, never ship it to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Email domain for the fake persona accounts. The default is a reserved,
# undeliverable TLD so these addresses can never collide with a real inbox.
# If Supabase rejects it, set a domain you control.
SEED_EMAIL_DOMAIN=seed.inkk.invalid
